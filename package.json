{
  "name": "electricity-trading",
  "private": true,
  "scripts": {
    "install:client": "cd client && npm install",
    "dev": "concurrently -n server,client -c blue,green \"npx tsx server/src/index.ts\" \"cd client && npx vite\"",
    "build": "npm run db:generate && npm run build:server && npm run install:client && npm run build:client",
    "build:server": "npx tsc -p server/tsconfig.json",
    "build:client": "cd client && npx vite build",
    "start": "node server/dist/index.js",
    "db:generate": "npx prisma generate --schema=server/src/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=server/src/prisma/schema.prisma --accept-data-loss",
    "db:seed": "npx tsx server/src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^22.13.4",
    "concurrently": "^9.1.0",
    "prisma": "^6.4.1",
    "tsx": "^4.22.0",
    "typescript": "^5.7.3"
  }
}
